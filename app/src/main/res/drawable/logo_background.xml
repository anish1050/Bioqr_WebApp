<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradient background for logo container -->
    <gradient
        android:startColor="#3B82F6"
        android:endColor="#10B981"
        android:angle="135"
        android:type="linear" />

    <!-- Rounded corners to make it look like a modern app icon -->
    <corners android:radius="16dp" />

    <!-- Optional: Add a subtle shadow effect with stroke -->
    <stroke
        android:width="1dp"
        android:color="#1E40AF" />

</shape>