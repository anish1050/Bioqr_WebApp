<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Background matching web app -->
    <item android:drawable="@color/bioqr_background" />
    
    <!-- Web app style gradients -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="80%p"
                android:centerX="50%"
                android:centerY="0%"
                android:startColor="#4D7877C6"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
    
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="70%p"
                android:centerX="90%"
                android:centerY="40%"
                android:startColor="#264F46E5"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
    
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="90%p"
                android:centerX="80%"
                android:centerY="100%"
                android:startColor="#1A06B6D4"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
    
</layer-list>