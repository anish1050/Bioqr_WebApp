<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/bioqr_primary_light_alpha30"> <!-- Ripple color: light primary with alpha -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@color/bioqr_primary_light" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bioqr_primary" /> <!-- Normal state background -->
            <corners android:radius="14dp" />
            <!-- You could add a gradient here if you want the CSS gradient on the button -->
            <!-- <gradient android:startColor="..." android:endColor="..." android:angle="135"/> -->
        </shape>
    </item>
</ripple>