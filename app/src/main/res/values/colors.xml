    <color name="bioqr_success">#10B981</color>
    <color name="bioqr_warning">#F59E0B</color>
    <color name="bioqr_danger">#EF4444</color>

    <!-- Borders -->
    <color name="bioqr_border">#1E293B</color> 
    <color name="bioqr_border_light">#334155</color>

