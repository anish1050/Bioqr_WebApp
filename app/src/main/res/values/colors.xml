<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Primary Palette (Blues) -->
    <color name="bioqr_primary">#3B82F6</color> <!-- Blue from the website -->
    <color name="bioqr_primary_light">#60A5FA</color> <!-- Lighter blue -->
    <color name="bioqr_primary_dark">#2563EB</color> <!-- Darker blue -->

    <!-- Secondary Palette (Biometric Blue) -->
    <color name="bioqr_secondary">#4361EE</color> <!-- The blue used in "Biometric Security" text -->
    <color name="bioqr_secondary_light">#605BFF</color>
    <color name="bioqr_secondary_dark">#3730A3</color>

    <!-- Accent Palette (Teal/Cyan) -->
    <color name="bioqr_accent">#06B6D4</color> <!-- Cyan from "Platform" text -->
