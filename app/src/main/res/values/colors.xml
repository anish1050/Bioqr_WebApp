    <color name="purple_500">@color/bioqr_primary</color>
    <color name="purple_700">@color/bioqr_primary_dark</color>
    <color name="teal_200">@color/bioqr_accent_light</color>
    <color name="teal_700">@color/bioqr_accent</color>
    <color name="black">#000000</color>
    <color name="white">#FFFFFF</color>

    <!-- Specific for LoginActivity based on your code -->
    <color name="success">@color/bioqr_success</color>
    <color name="error">@color/bioqr_danger</color>

    <color name="bioqr_primary_light_alpha30">#4D6366F1</color> <!-- 30% alpha of bioqr_primary_light -->

