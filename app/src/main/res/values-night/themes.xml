<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BioQR" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/bioqr_primary</item>
        <item name="colorPrimaryVariant">@color/bioqr_primary_dark</item> <!-- Or bioqr_primary_light -->
        <item name="colorOnPrimary">@color/bioqr_text_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/bioqr_accent</item>
        <item name="colorSecondaryVariant">@color/bioqr_accent_dark</item> <!-- Or bioqr_accent_light -->
        <item name="colorOnSecondary">@color/bioqr_text_primary</item> <!-- Or black if accent is very light -->

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bioqr_background</item>
        <item name="android:navigationBarColor">@color/bioqr_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item> <!-- Text and icons on status bar will be light -->

        <!-- Background colors -->
        <item name="android:colorBackground">@color/bioqr_background</item>
        <item name="colorSurface">@color/bioqr_card_background</item> <!-- For CardView, Dialogs, Menus -->
        <item name="colorOnBackground">@color/bioqr_text_primary</item>
        <item name="colorOnSurface">@color/bioqr_text_primary</item>
        <item name="colorError">@color/bioqr_danger</item>
        <item name="colorOnError">@color/bioqr_text_primary</item>

        <!-- Typography -->
        <item name="android:fontFamily">@font/inter_font_family</item>
        <item name="fontFamily">@font/inter_font_family</item>
        <item name="android:textColor">@color/bioqr_text_primary</item>
        <item name="android:textColorHint">@color/bioqr_text_muted</item>

        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="textInputStyle">@style/Widget.App.TextInputLayout</item>
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>

        <!-- Control Activated/Checked state colors -->
        <item name="colorControlActivated">@color/bioqr_primary</item>
        <item name="colorControlNormal">@color/bioqr_text_muted</item> <!-- For unchecked checkbox/radio button color -->

        <!-- Window background for the subtle gradients -->
        <!-- This is a bit advanced; for a simpler start, you can skip and use solid bioqr_background -->
        <item name="android:windowBackground">@drawable/window_background_gradient</item>

    </style>

    <style name="Theme.BioQR" parent="Base.Theme.BioQR" />

    <!-- Specific Widget Styles -->
    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/bioqr_text_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="android:letterSpacing">0.02</item>
        <!-- Use gradient background to match web app -->
        <item name="android:background">@drawable/button_gradient_background</item>
    </style>

    <style name="Widget.App.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/bioqr_primary_selector</item> <!-- Selector for hover effect -->
        <item name="android:textColor">@color/bioqr_text_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
        <!-- Ripple for background changes on hover/press -->
        <item name="rippleColor">@color/bioqr_primary_light_alpha30</item>
        <item name="android:backgroundTint">#00000000</item> <!-- Transparent background, stroke provides color -->
    </style>


    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/bioqr_primary_selector</item>
        <item name="hintTextColor">@color/bioqr_primary</item>
        <item name="boxBackgroundColor">@color/bioqr_card_background_elevated</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="Widget.App.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bioqr_card_background</item>
        <item name="cardElevation">4dp</item> <!-- Adjust as needed for desired shadow -->
        <item name="cardCornerRadius">24dp</item> <!-- Translating 1.5rem -->
    </style>

    <!-- Text Appearances -->
    <style name="TextAppearance.App.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/inter_black</item> <!-- or inter_extrabold -->
        <item name="android:textColor">@color/bioqr_text_primary</item>
        <item name="lineHeight">48sp</item> <!-- Approximating CSS line-height: 1.1 for large text -->
    </style>

    <style name="TextAppearance.App.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textColor">@color/bioqr_text_primary</item>
    </style>

    <style name="TextAppearance.App.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/bioqr_text_secondary</item>
        <item name="lineHeight">28sp</item> <!-- Approximating CSS line-height 1.7 -->
    </style>

    <style name="TextAppearance.App.HeroBadge" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="android:textColor">@color/bioqr_primary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

</resources>